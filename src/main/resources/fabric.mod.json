{
  "schemaVersion": 1,
  "id": "ingenium",
  "version": "${version}",
  "name": "Ingenium",
  "description": "The World's First Adaptive Performance Intelligence System for Minecraft. Complements Sodium, Lithium, and FerriteCore with unique optimizations they don't cover.",
  "authors": [
    "Ingenium Team"
  ],
  "contact": {
    "homepage": "https://github.com/ingenium/ingenium-optimization",
    "sources": "https://github.com/ingenium/ingenium-optimization",
    "issues": "https://github.com/ingenium/ingenium-optimization/issues"
  },
  "license": "LGPL-3.0",
  "icon": "assets/ingenium/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.ingenium.core.Ingenium"
    ],
    "client": [
      "com.ingenium.client.IngeniumClient",
      "toni.sodiumoptionsapi.SodiumOptionsAPI"
    ]
  },
  "mixins": [
    "ingenium.mixins.json",
    "sodiumoptionsapi.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.14.21",
    "fabric-api": "*",
    "minecraft": "1.20.1"
  },
  "suggests": {
    "sodium": "*",
    "lithium": "*",
    "ferritecore": "*",
    "starlight": "*",
    "spark": "*"
  },
  "conflicts": {
    "optifine": "*",
    "optifabric": "*"
  },
  "breaks": {
    "optifine": "*",
    "optifabric": "*"
  }
}