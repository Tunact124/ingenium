{
  "schemaVersion": 1,
  "id": "ingenium",
  "version": "${version}",
  "name": "Ingenium",
  "description": "The World's First Adaptive Performance Intelligence System for Minecraft. Complements Sodium, Lithium, and FerriteCore with unique optimizations they don't cover.",
  "authors": [
    "Ingenium Team"
  ],
  "contact": {
    "homepage": "https://github.com/ingenium/ingenium-optimization",
    "sources": "https://github.com/ingenium/ingenium-optimization",
    "issues": "https://github.com/ingenium/ingenium-optimization/issues"
  },
  "license": "LGPL-3.0",
  "icon": "assets/ingenium/icon.png",
  "environment": "*",
  "entrypoints": {
    "main":    ["com.ingenium.IngeniumMod"],
    "client":  ["com.ingenium.client.IngeniumClient"],
    "modmenu": ["com.ingenium.config.IngeniumModMenu"]
  },
  "mixins": ["ingenium.mixins.json"],
  "depends": {
    "fabricloader":              ">=0.14.21",
    "fabric-api":                "*",
    "minecraft":                 "1.20.1",
    "yet_another_config_lib_v3": ">=3.4.0",
    "modmenu":                   "*"
  },
  "suggests": {
    "sodium": "*",
    "lithium": "*",
    "ferritecore": "*",
    "starlight": "*",
    "spark": "*",
    "modmenu": "*"
  },
  "conflicts": {
    "optifine": "*",
    "optifabric": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "https://discord.gg/ingenium"
      },
      "update_checker": true
    }
  },
  "breaks": {
    "optifine": "*",
    "optifabric": "*"
  }
}
